         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">New York State Wine Grape Growers records, 
		</unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1965-1991.</unitdate>
