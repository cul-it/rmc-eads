         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Perrine family papers, 
        </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1793-1908.</unitdate>
