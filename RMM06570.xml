         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Johnnie Parrish papers, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1979-1994.</unitdate>
         <unitid label="Collection Number:">6570</unitid>
