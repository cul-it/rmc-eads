			<unittitle encodinganalog="MARC 245" label="Title:">Boyd McDonald papers, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1925-1993.</unitdate>
			<unitid label="Collection Number:">7782</unitid>
