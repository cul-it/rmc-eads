         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Stuart Otto papers, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1918-1940.</unitdate>
         <unitid label="Collection Number:">2389</unitid>
