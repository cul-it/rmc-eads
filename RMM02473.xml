         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Robert Moody papers, </unittitle>
         <unitdate encodinganalog="MARC 245" type="inclusive">1842-1978.</unitdate>
         <unitid label="Collection Number:">2473</unitid>
