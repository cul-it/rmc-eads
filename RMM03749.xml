         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Philip Will, Jr. papers, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1941-1985.</unitdate>
         <unitid label="Collection Number:">3749</unitid>
