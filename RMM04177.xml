         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Katherine V. W. Palmer and Ephraim
            Laurence Palmer memorabilia, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1918-1978,</unitdate><unitdate encodinganalog="MARC 245" type="bulk">1952-1978 (bulk)</unitdate>
         <unitid label="Collection Number:">4177</unitid>
