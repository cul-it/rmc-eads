         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Northern Nut Growers Association records, 
		  </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1892-1948.</unitdate>
