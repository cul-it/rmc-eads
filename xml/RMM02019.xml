 id="aspace_1ef96463771e91987bf0534c05a4099b" level="item"><did><unittitle>N.Y.O. &amp; W. train with Engine No. 68 with two railroad men in front. Undated.</unittitle><container id="aspace_e147a20ffbd6c0e0d9346b798846a7b8" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_cbd411fa425bad56f807b77d984e21de" level="item"><did><unittitle>Engine with "Pittston" and L.V.R. on the front. Undated.</unittitle><container id="aspace_d8d168f1689c66a0d9bc41636df71bef" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_de17f9a4ef4e208f9481f6433f1c7e93" level="item"><did><unittitle>Engine with four men in front and one in the engine. Undated.</unittitle><container id="aspace_7d0a6f839b5b27595966ee01e71ab9cb" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01></dsc>
