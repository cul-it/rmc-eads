 id="aspace_1ef96463771e91987bf0534c05a4099b" level="item"><did><unittitle>N.Y.O. &amp; W. train with Engine No. 68 with two railroad men in front. Undated.</unittitle><container id="aspace_8ca0968cb1b11bc8749ecc4c080548e1" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_cbd411fa425bad56f807b77d984e21de" level="item"><did><unittitle>Engine with "Pittston" and L.V.R. on the front. Undated.</unittitle><container id="aspace_0587c3750d7b7d8fdc551102e8ddfa93" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_de17f9a4ef4e208f9481f6433f1c7e93" level="item"><did><unittitle>Engine with four men in front and one in the engine. Undated.</unittitle><container id="aspace_6dae1862df83bd3ae0a792f85c20602b" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01></dsc>
