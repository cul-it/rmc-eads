  <dsc><c01 id="aspace_2be31c815a52d8a3938490ebd047a69c" level="item"><did><unittitle>N.Y.O. - H.R. [Hudson River?] Railroad. White Car Mail Train,</unittitle><unitdate calendar="gregorian" datechar="creation" era="ce" normal="1890/1890">1890.</unitdate><container id="aspace_8f53107b6b3a94c027c524ba117f8d2c" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_5acfea284274ab974fb38e6e1d1f815c" level="item"><did><unittitle>Engine named "Pharsalia." Built by Baldwin in 1872. Sold in 1872. Was placed in class "F" (maybe for funny looking??).</unittitle><unitdate calendar="gregorian" datechar="creation" era="ce" normal="1872/1872">1872</unitdate><container id="aspace_7bcb3e1f4e244b49db96f99c9128ad0c" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_6c351e1bb560bc6275252ad6728aa84e" level="item"><did><unittitle>Engine No. 61 with six men in front. Northern Division. Copied from a print Harold Walker had in 1948. Undated, but early.</unittitle><container id="aspace_6d186bda2f01d5fb0524a6f3b7c26f12" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_087684243d63b7ff689d567ca0a4b036" level="item"><did><unittitle>Freight yard, Weehawken, New Jersey.</unittitle><unitdate calendar="gregorian" datechar="creation" era="ce" normal="1959-10-02/1959-10-02">Oct. 2, 1959.</unitdate><container id="aspace_70418448ac722783efa4fa79fcbf6d09" label="Mixed Materials [31924065254546]" type="manuscript box">80 - Folder 1</container></did></c01><c01 id="aspace_b0f128ac36d361d52eba82a3c5b09d4b" level="item"><did><unittitle>New York, Ontario and Western coal docks, no rails, Weehawken, New Jersey,</unittitle><unitdate calendar="gregorian" datechar="creation" era="ce" normal="1959-10-02/1959-10-02">Oct. 2, 1959.</unitdate><container id="aspace_801402f4436e15e8d1e8d2162d05bab3" label="Mixed Materials [3192