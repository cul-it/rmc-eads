4916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_a20307be75ab0e6c36ba2b9e5e8be8cd"><head>Scope and Contents</head><p>Given by E. W. Scott &amp; AL and E.W.  Scott</p></scopecontent></c02><c02 audience="internal" id="aspace_53859835b72fc50ce9efea0eed27bd96" level="file"><did><unittitle>Copy of Indenture</unittitle><unitdate datechar="creation" normal="1872-01-20/1872-01-20" type="inclusive">1872-01-20</unitdate><container id="aspace_b2e4011c187c4cd92f888b42b4d101cd" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_dcf02d192a487cf810d6cae475aab03b"><head>Scope and Contents</head><p>WHS to EWS  $2,000</p></scopecontent></c02><c02 audience="internal" id="aspace_5f191f9527bb9d4503f4b494439c1135" level="file"><did><unittitle>Contract Clark Bush and Edwin Scott</unittitle><unitdate datechar="creation" normal="1873-06-03/1873-06-03" type="inclusive">1873-06-03</unitdate><container id="aspace_8cc5fadaedd9b540395bf3a99f9789b1" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_52e51b591206045c82d6685cba816af7"><head>Scope and Contents</head><p>For latter to sell former's patented gate and fence in parts of Penn.  Power of Attorney</p></scopecontent></c02><c02 audience="internal" id="aspace_fa50656165f69ce6944518a70b1e7e5a" level="file"><did><unittitle>Emmet to Edwin and brother</unittitle><unitdate datechar="creation" normal="1873-05-11/1873-05-23" type="inclusive">1873-05-11-1873-05-23</unitdate><container id="aspace_cfadf7d44bbcad786fa795b48dd24b9b" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_4791c795c201965b2062b13f9efeadf6"><head>Scope and Contents</head><p>re: death of daughter</p></scopecontent></c02><c02 audience="internal" id="aspace_5bf6537616302fbd75f359ff52082c2e" level="file"><did><unittitle>Statement of Inventory</unittitle><unitdate datechar="creation" normal="1874-12-04/1874-12-04" type="inclusive">1874-12-04</unitdate><container id="aspace_40ffb107ca3af7e299f28385bca1c4dc" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_c73d6a999e848a3d9114e0bbff643432"><head>Scope and Contents</head><p>Inventory and Appraisement of personal property of W.H. Scott</p></scopecontent></c02><c02 audience="internal" id="aspace_40549743a5fd135954f6a28436784967" level="file"><did><unittitle>Detailed Statement of Cash Received</unittitle><unitdate datechar="creation" normal="1874-11-14/1874-11-14" type="inclusive">1874-11-14</unitdate><container id="aspace_7edb23a2edda272ade7ea0051db6e028" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_02f766e6bac2b3b3c2cb51f3f0df6229"><head>Scope and Contents</head><p>By E.H. Scott as executor of the last Will and Testament of W.H. Scott</p></scopecontent></c02><c02 audience="internal" id="aspace_7062d1a2962521492e1bfc9ff54f50c4" level="file"><did><unittitle>Summons by Riley Bush</unittitle><unitdate datechar="creation" normal="1875-01-23/1875-01-23" type="inclusive">1875-01-23</unitdate><container id="aspace_a6b9df9e73a4668937ab42d9ffb89c9b" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_0ec78679561674b41a34bfa5cc0f6fab"><head>Scope and Contents</head><p>Summons by Riley Bush against Edwin, Emmet et al. for $600 owed by Edwin</p></scopecontent></c02><c02 audience="internal" id="aspace_2b29daa9591308bd665349cb45e8acbc" level="file"><did><unittitle>Injunction</unittitle><unitdate datechar="creation" normal="1875-01-30/1875-01-30" type="inclusive">1875-01-30</unitdate><container id="aspace_0d4bbc730d074acc4da69607d8ebf844" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_b6d684579b28e992563ea6871cad39d5"><head>Scope and Contents</head><p>Against Abbey Scott for above $600</p></scopecontent></c02><c02 audience="internal" id="aspace_7ef20735062f57b1351cafeaec7a5c15" level="file"><did><unittitle>Legal description of Brewery property</unittitle><unitdate calendar="gregorian" datechar="creation" era="ce">date unknown</unitdate><container id="aspace_5c16c8bb80e14bf01c8518dbbb2ed229" label="Mixed Materials [31924064916483]" type="box">1</container></did></c02><c02 audience="internal" id="aspace_b32141231c8db7038e158c4a9b5dd6c2" level="file"><did><unittitle>Broadside</unittitle><unitdate calendar="gregorian" datechar="creation" era="ce">date unknown</unitdate><container id="aspace_e714471a8e5ba4153a4bbe38c86848f1" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_de5026cb6c86b61caa03b273c009664d"><head>Scope and Contents</head><p>C.T. Bush's Iron Fence</p></scopecontent></c02><c02 audience="internal" id="aspace_d556eda82c2b18d64cae5ad16e53c3f7" level="file"><did><unittitle>Copy of Condensed Description of Deed for land in Randolph Co., Va.</unittitle><unitdate calendar="gregorian" datechar="creation" era="ce">date unknown</unitdate><container id="aspace_410e62f979f9e4dc1ee35c31990864b7" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_7766ab0b32a2b1759781d0290ae4f1fe"><head>Scope and Contents</head><p>Copy of Deed - letter on back from "Jamie" to Edwin.   "Brother Edwin" from Silas, Chicago - has rented farm to Hamilton Dean.  About 5,000 secessionists captured and brought to Chicago - came over our road - comfortably clothed, but few with overcoats.  Kentuckians and Tennesseans appear to be glad they were captured.  Not so of Mississippians.  All of rank and file very ignorant,  say they have been misled, they expected to be abused and jeered at in a free state but have been treated kindly.  A majority of our volunteers from this state, Indiana to Missouri no more intelligent than the sec'y. Most go for pay and not for any particular principle...comments on E's recent marriage. Decided to bury his objections and E's marrying so young.  Might buy his father's Dickinson lot and leave RR where he is now working.</p></scopecontent></c02><c02 audience="internal" id="aspace_b9d2cece5cdf15e72b671c436d3122e4" level="file"><did><unittitle>Henry R. Mygatt to Wiley H. Scott Esq.</unittitle><unitdate datechar="creation" normal="1863-11-19/1863-11-19" type="inclusive">1863-11-19</unitdate><container id="aspace_6792eec6241d0b03cbff42b5a192d1d0" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_956ca977f91f8232db1329a7fe1e227a"><head>Scope and Contents</head><p>Henry R. Mygatt (Oxford lawyer?) to Wiley H. Scott Esq. re: latter's case</p></scopecontent></c02><c02 audience="internal" id="aspace_2503e785b2cb41f220ea733e13a68d68" level="file"><did><unittitle>Henry R. Mygatt to Wiley H. Scott Esq.</unittitle><unitdate datechar="creation" normal="1864-02-05/1865-09-18" type="inclusive">1864-02-05-1865-09-18</unitdate><container id="aspace_468ccd7b72149df9563559b4b81b7c9b" label="Mixed Materials [31924064916483]" type="box">1</container></did><scopecontent audience="internal" id="aspace_9e07fc75bfe184d9101027ed7c23678d"><head>Scope and Contents</head><p>Henry R. Mygatt (Oxford lawyer?) to Wiley H. Scott Esq. re: ejectment suit</p></scopecontent></c02><c02 audience="internal" id="aspace_4af6e1d95550977420aa364cbdaf2b1c" level="file"><did><unittitle>W.H. Scott to H.R. Mygatt</unittitle><unitdate datechar="creation" normal="1868-09-18/1868-09-18" type="inclusive">1868-09-18</unitdate><container id="aspace_7334c529afc9c652cfc62e2ba28f8700" label="Mixed Materials [31924064916483]" type="box">1</container></did></c02><c02 audience="internal" id="aspace_f1609da5d843c3678fc4b35f4efe9630" level="file"><did><unittitle>Agreement between Wiley H.. Scott and Edwin W. Scott</un