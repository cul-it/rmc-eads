			<unittitle encodinganalog="MARC 245" label="Title:">Cornell University diploma and
				certificate collection, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1876-1948.</unitdate>
			<unitid label="Collection Number:">37-5-2637</unitid>
			<origination label="Creator:"><corpname encodinganalog="MARC 110">Cornell
					University.</corpname></origination>
			<physdesc encodinganalog="MARC 300" label="Quantity:"><extent>1.5 cubic feet</extent></physdesc>
			<physdesc label="Forms of Material:">Diplomas and certificates.</physdesc>
			<repository label="Repository:">Division of Rare and Manuscript Collections, Cornell
				University Library</repository>
			<abstract label="Abstract:">Collection consists primarily of Cornell diplomas from
				alumni, but also includes some Cornell certificates and non-Cornell
				certificates/diplomas from alumni.</abstract>
			<langmaterial label="Language:">Collection material in <language encodinganalog="041" langcode="eng">English</language></langmaterial>
		</did>
		<scopecontent encodinganalog="MARC 520">
			<head id="a3">COLLECTION DESCRIPTION</head>
			<p>Collection consists primarily of Cornell diplomas from alumni, but also includes some
				Cornell certificates and non-Cornell certificates/diplomas from alumni.</p>
			<p>Also, some empty mailing tubes and the bottom piece of a February 8, 1922
				diploma.</p>
		</scopecontent>
