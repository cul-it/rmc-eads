 id="aspace_0502d5fe16c4747e63c94fb00fad9231" label="Mixed Materials [31924081665824]" type="box">2</container></did></c03><c03 audience="internal" id="aspace_bdb4336974824a3e9888d95a752354f8" level="file"><did><unittitle>Inventory of the estate of Amos L. Kenney  (2 copies)</unittitle><unitdate normal="1908-07-15/1908-07-15" type="inclusive">1908-07-15</unitdate><container id="aspace_38b4b5397456663513e5bcddc1d612d2" label="Mixed Materials [31924081665816]" type="box">3</container></did></c03><c03 audience="internal" id="aspace_60e9a2a03e052fda3d4ff9623cc7b2d9" level="file"><did><unittitle>One Mss. Sheet of music  "To Father"</unittitle><unitdate calendar="gregorian" era="ce">date unknown</unitdate><container id="aspace_c9583af8489d4fe72d48e028b67ed3b1" label="Mixed Materials [31924081665816]" type="box">3</container></did><scopecontent audience="internal" id="aspace_1b2256e98fd9ad70dce2f8e07279522e"><head>Scope and Contents</head><p>Words and music by Eudorus C. Kenney</p></scopecontent></c03><c03 audience="internal" id="aspace_a20c3018208a867b49dcc4993114d1d0" level="file"><did><unittitle>One printed sheet of music "To Father"</unittitle><unitdate calendar="gregorian" era="ce">date unknown</unitdate><container id="aspace_a9e1a51788dd10a417d63e1477ad7279" label="Mixed Materials [31924081665816]" type="box">3</container></did><scopecontent audience="internal" id="aspace_e02af7a62610da1ab4b4d5f3b5d59b15"><head>Scope and Contents</head><p>Words and music by Eudorus C. Kenney</p></scopecontent></c03></c02><c02 audience="internal" id="aspace_41d118e5bf7d62f305e30495ef000296" level="subseries"><did><unittitle>I.b. Letters of note</unittitle></did><scopecontent audience="internal" id="aspace_2b9a3ceb068b6005fd11463b5989a4dd"><head>Scope and Contents</head><p>(other than thank yous or requests)</p></scopecontent><c03 audience="internal" id="aspace_af8e561c690bc01670cf981b330893c6" level="file"><did><unittitle>Rev. James Dobbin, Rector of The Bishop Seabury Mission</unittitle><unitdate normal="1890-01-03/1890-01-03" type="inclusive">1890-01-03</unitdate><container id="aspace_254e1b0d083cc3fdadab369f8077195d" label="Mixed Materials [31924081665774]" type="box">1</container></did><scopecontent audience="internal" id="aspace_d1a071b10872712d6a8ddef64844e1a5"><head>Scope and Contents</head><p>Refuses to appoint E.C.K. as Prof. in Math Department despite excellent recommendations because "you are not at one with us in our religious faith and life"</p></scopecontent></c03><c03 audience="internal" id="aspace_7a41909d03e24afaab900d36034854eb" level="file"><did><unittitle>The Brooklyn Ethical Association</unittitle><unitdate normal="1890-10-06/1890-10-06" type="inclusive">1890-10-06</unitdate><container id="aspace_e8c8e44a5b84ac97d944901b5a1c931d" label="Mixed Materials [31924081665774]" type="box">1</container></did><scopecontent audience="internal" id="aspace_e4dc73f965e515a142f676243637c3ad"><head>Scope and Contents</head><p>Informing E.C.K. of his election as a corresponding member; lists topics connected with association's work; signed by James A. Skilton, corresponding secretary.</p></scopecontent></c03><c03 audience="internal" id="aspace_e25e274af6367ccb5f9eff04a95309b2" level="file"><did><unittitle>Milton C. Brown, Eddy St. Ithaca</unittitle><unitdate normal="1892-08-11/1892-08-11" type="inclusive">1892-08-11</unitdate><container id="aspace_1e360368bb94dc441008d27fc8072888" label="Mixed Materials [31924081665774]" type="box">1</container></did><scopecontent audience="internal" id="aspace_a3a27a480f02be03a1a4dd640fd7d9fa"><head>Scope and Contents</head><p>Describes own theories of electricity, water-witching, etc.  (3 sheets)</p></scopecontent></c03><c03 audience="internal" id="aspace_94337ee32d34605ea59fc3123b9d3f72" level="file"><did><unittitle>Milton C. Brown, Eddy St. Ithaca</unittitle><unitdate normal="1892-08-16/1892-08-16" type="inclusive">1892-08-16</unitdate><container id="aspace_49689687e3c005ef4d29908294889145" label="Mixed 