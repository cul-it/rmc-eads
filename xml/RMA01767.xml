         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">New York State College of Agriculture and Life Sciences. Development and Alumni Affairs records, 

		</unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1960-1995.</unitdate>
