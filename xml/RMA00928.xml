e6808e80c6168" parent="aspace_cf18a93f57d0c811eb043e39e6b59847" type="folder">1</container></did><scopecontent id="aspace_111ba22cffb1d27a4c1a7951135fe482"><head>Scope and Contents</head><p>Individuals include Anna Eliza Jekins and family, Angelo da Costa Lima, Agesilau Antonio Bitancourt and family, and Benjamin Hunnicutt and family, and other friends and colleagues of Jekins.</p></scopecontent></c01><c01 id="aspace_1f2723e18fe9ad4540b478697daf2555" level="file"><did><unittitle>Photographs - Travel photos</unittitle><unitdate certainty="approximate" datechar="creation" normal="1935/1953" type="inclusive">1935-1938, 1953</unitdate><container id="aspace_e052bfa7b00e3bc060c664926e2a0bc4" label="Mixed Materials [31924131178984]" type="box">2</container><container id="aspace_f3ec15e079ad3c44b2c20451cfbf1e36" parent="aspace_e052bfa7b00e3bc060c664926e2a0bc4" type="folder">2</container></did><scopecontent id="aspace_da37d3c490604136d2d72b6a453a28a5"><head>Scope and Contents</head><p>Locations include Saint Caterina, Jaraguá, Tremembé, Urca, Paquetá, Rio de Janeiro, and Sao Paulo, Brazil, as well as a small amount of photos of Argentina and Trinidad. Individuals in photos include the Bitancourt family. Includes a photo of the LZ 127 Graf Zeppelin over Rio de Janeiro, ca. 1936. Photographs from 1935 to 1938 were removed from a scrapbook documenting Jenkin's travels. For ephemera from the cruises, see folder 19 in box 1.</p></scopecontent></c01><c01 id="aspace_7fa9edd2053740029735f4b12546250d" level="file"><did><unittitle>Photographs - Porto Alegre souvenir photobook</unittitle><unitdate calendar="gregorian" certainty="approximate" datechar="creation" era="ce">Undated</unitdate><container id="aspace_9c242673c37c0162e48fcc88d307ee2d" label="Mixed Materials [31924131178984]" type="box">2</container><container id="aspace_5a060f38a870d9f1b39943ba97315182" parent="aspace_9c242673c37c0162e48fcc88d307ee2d" type="folder">2</container></did></c01><c01 id="aspace_c709943075ae5b99d662fd