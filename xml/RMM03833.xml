         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Cayuga Trails Club records, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1957-2012.</unitdate>
         <unitid label="Collection Number:">3833</unitid>
