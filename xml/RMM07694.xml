         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Russian lesbian, gay, and AIDS-related
            publications and ephemera, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1992-1997.</unitdate>
