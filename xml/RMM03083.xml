			</origination>
			<physdesc encodinganalog="MARC 300" label="Quantity:"><extent>22 cubic feet</extent></physdesc>
			<physdesc label="Forms of Material:">Printed Materials, Research Materials,
				Scrapbooks</physdesc>
			<repository label="Repository:">Division of Rare and Manuscript Collections, Cornell
				University Library</repository>
			<abstract label="Abstract:">Subject files of committees, minutes of meetings, reports,
				records of death associated with pregnancy and childbirth, constitution and bylaws
				as amended June 1876, financial records, pamphlets, and scrapbooks of the Medical
				Society of the County of Monroe, Inc.</abstract>
			<langmaterial label="Language:">Collection material in <language encodinganalog="041" langcode="eng">English</language></langmaterial>
		</did>
		<bioghist encodinganalog="MARC 545">
			<head altrender="organization" id="a2">ORGANIZATIONAL HISTORY </head>
			<p>The Medical Society of the County of Monroe was formed in 1821.</p>
		</bioghist>
		<scopecontent encodinganalog="MARC 520">
			<head id="a3">COLLECTION DESCRIPTION</head>
			<p>Subject files of committees, minutes of meetings, reports, records of death
				associated with pregnancy and childbirth, constitution and bylaws as amended June
				1876, financial records, pamphlets, and scrapbooks of the Medical Society of the
				County of Monroe, Inc.</p>
		</scopecontent>
