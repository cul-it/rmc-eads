pace_745e91d18babd27239d88623681da16a" type="folder">5</container></did></c01><c01 id="aspace_1456616a0bc2275597fd8ec450ef6ed8" level="file"><did><unittitle>Pamphlets</unittitle><container id="aspace_bdf78d0009da90937bb50994ac56ce31" label="Mixed Materials [31924081664876]" type="box">7</container><container id="aspace_e176d82e7633145b2cfc4f230f1a71aa" parent="aspace_bdf78d0009da90937bb50994ac56ce31" type="folder">6</container></did></c01><c01 id="aspace_d716494398f49635ff0621c22a6789c7" level="file"><did><unittitle>Paperbound book, <title>Memoirs of the National Academy of Science</title>, vol. XX (Washington: Government Printing Office, 1924 ). The whole of this volume compromises "The American Oaks," by William Trelease.</unittitle><unitdate calendar="gregorian" era="ce" normal="1924/1924">1924</unitdate><container id="aspace_f90427850d813961884553d27dcf10b0" label="Mixed Materials [31924081664876]" type="box">7</container></did></c01><c01 id="aspace_563138c30c4943a12129db08186af5af" level="file"><did><unittitle>Additional papers</unittitle><unitdate calendar="gregorian" certainty="inferred" era="ce" normal="1914/1914">1914-[1940-1945]</unitdate><container id="aspace_38f98e20743bd6a35d91f7838ea50dd1" label="Mixed Materials [31924081656583]" type="box">8</container></did><scopecontent id="aspace_9ee5a06ed5059f1bd0ed4071641138cb"><head>Scope and Contents</head><p>These additional papers consist mainly of letters from relatives, friends, colleagues, and ex-students on his 80th (1937) and 83rd (1940) birthdays, and letters of condolence (1945) to his widow and children; also included are Trelease's correspondence, deeds, and drawings concerning family cemetery plots in Urban, Illinois and St. Louis, Missouri; <title>William Trelease, Personal Reminiscences</title> by J. Christian Bay (12 pp. pamphlet, 1945); photographs of Trelease; and related printed matter and newspaper clippings. Ca. 150 pcs.</p><list type="ordered"><head>Correspondents of William Trelease:</head><item>John W. Spargo - cousin - professor at Northwestern University</item><item>Jonibel Blair - granddaughter</item><item>Hillebrand - English professor - Harvard A.B. and Ph.D.</item><item>Albert L. Lybyer - professor of history at Illinois</item><item>Abram Leon Sacher - president of Brandeis University now</item><item>Cecelia Tonton - daughter of H.B. Ward</item><item>Kaltienn M. Noyes - widow of W.A. Noyes (chemist)</item><item>Leighton - Ill. State Geological Survey</item><item>Frank W. Scott - with D.C. Heat, formerly professor at Illinois</item><item>Eunice Daniels - widow of Pres. Daniels</item></list></scopecontent></c01></dsc>
