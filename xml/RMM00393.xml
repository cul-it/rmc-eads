         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Van Schaick family papers, 

		  </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1732-1846.</unitdate>
