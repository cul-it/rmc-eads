			<head id="a1">DESCRIPTIVE SUMMARY</head>
			<unittitle encodinganalog="MARC 245" label="Title:">Statler Club records, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1943-1998.</unitdate>
			<unitid label="Collection Number:">28-8-1802</unitid>
			<origination label="Creator:"><corpname encodinganalog="MARC 110">Statler Club (Cornell
					University)</corpname></origination>
			<physdesc encodinganalog="MARC 300" label="Quantity:"><extent>3.6 cubic feet</extent></physdesc>
			<physdesc label="Forms of Material:">Legal documents, printed materials, reports.</physdesc>
			<repository label="Repository:">Division of Rare and Manuscript Collections, Cornell
				University Library</repository>
			<abstract label="Abstract:">Includes constitution and bylaws, committee records,
				correspondence, minutes of the Board of Directors, and other records of the Statler
				Club, Cornell University. Also, records kept by Charles Sibley, President of the
				Statler Club, 1957-1958 and records kept by Jane Hardy, 1993-1998.</abstract>
			<langmaterial label="Language:">Collection material in <language encodinganalog="041" langcode="eng">English</language></langmaterial>
		</did>
		<scopecontent encodinganalog="MARC 520">
			<head id="a3">COLLECTION DESCRIPTION</head>
			<p>Includes constitution and bylaws, committee records, correspondence, minutes of the
				Board of Directors, and other records of the Statler Club, Cornell University. Also,
				records kept by Charles Sibley, President of the Statler Club, 1957-1958 and records
				kept by Jane Hardy, 1993-1998.</p>
			<p>Includes bound dinner menus (1950-1953) and luncheon menus (1950-1956) from the
				Statler Club.</p>
		</scopecontent>
