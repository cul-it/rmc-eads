			<head id="a1">DESCRIPTIVE SUMMARY</head>
			<unittitle encodinganalog="MARC 245" label="Title:">Robert Stuart collection, </unittitle><unitdate certainty="approximate" encodinganalog="MARC 245" type="inclusive">1970-1981.</unitdate>
			<unitid label="Collection Number:">7831</unitid>
