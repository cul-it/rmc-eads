    <archdesc level="collection">
        <did>
            <head id="a1">DESCRIPTIVE SUMMARY</head>
            <unittitle encodinganalog="MARC 245" label="Title:">Cornell Fraternity and Sorority
                Affairs Office records, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1960-2009.</unitdate>
            <unitid label="Collection Number:">37-4-3027</unitid>
            <origination label="Creator:">
                <corpname encodinganalog="110" normal="Cornell University. Fraternity and Sorority Affairs Office. ">Cornell
                    University. Fraternity and Sorority Affairs Office. </corpname>
            </origination>
            <physdesc encodinganalog="MARC 300" label="Quantity:"><extent>1 collection</extent>

<extent>2.5 cubic
                ft.</extent></physdesc>
            <physdesc label="Forms of Material:">Scrapbooks, photographs, correspondence, rush
                books, bylaws, annual reports, newsletters, newspaper clippings, pamphlets, and
                ephemera.</physdesc>
            <repository label="Repository:">Division of Rare and Manuscript Collections, Cornell
                University Library</repository>
            <abstract label="Abstract:">Includes scrapbooks, photographs, correspondence, rush
                books, bylaws, annual reports, newsletters, newspaper clippings, pamphlets, and
                ephemera of fraternities and sororities at Cornell University. Also, t-shirt from
                Cornell Greek Week, 2003.</abstract>
            <abstract label="Abstract:">Annual reports from the Fraternity and Sorority Advisory
                Council, 1997-2009; Guide and Map of the Fraternities &amp; Sororities, 2003-2009;
                and brochures.</abstract>
            <langmaterial label="Language:">Collection material in <language encodinganalog="041" langcode="eng">English</language>
            </langmaterial>
        </did>
        <scopecontent encodinganalog="MARC 520">
            <head id="a3">COLLECTION DESCRIPTION</head>
            <p>Includes scrapbooks, photographs, correspondence, rush books, bylaws, annual reports,
                newsletters, newspaper clippings, pamphlets, and ephemera of fraternities and
                sororities at Cornell University. Also, t-shirt from Cornell Greek Week, 2003.</p>
            <p>Annual reports from the Fraternity and Sorority Advisory Council, 1997-2009; Guide
                and Map of the Fraternities &amp; Sororities, 2003-2009; and brochures.</p>
        </scopecontent>
