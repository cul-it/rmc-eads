="box">1</container><container id="aspace_363766ab8483cda71f4d8d2190aeb8e3" parent="aspace_6b4de7574494088e4920f80e39547a32" type="folder">13</container></did></c02><c02 id="aspace_dd7d8144c4a13c73fe16045ec56d3cb6" level="file"><did><unittitle>Prog. effort</unittitle><container id="aspace_42dcb8a4f606ba73a997154ce64cafc9" label="Mixed Materials [31924065231767]" type="box">1</container><container id="aspace_59bd21f412f81a20c6c70485333d56a4" parent="aspace_42dcb8a4f606ba73a997154ce64cafc9" type="folder">14</container></did></c02><c02 id="aspace_f581d5f519614415bde44db1ce22ff24" level="file"><did><unittitle>Misc. ques.</unittitle><container id="aspace_b32ac0a2827348cc6c73c0b34a6b765a" label="Mixed Materials [31924065231767]" type="box">1</container><container id="aspace_79fdd898532cda011c2009fe292dfbfd" parent="aspace_b32ac0a2827348cc6c73c0b34a6b765a" type="folder">15</container></did></c02></c01><c01 id="aspace_b5cef2452c9141ed1742a0b04668c92e" level="series"><did><unittitle>Series III. SEAPRS</unittitle></did><scopecontent id="aspace_8c53b738735397eb8a81975c7e9ae9ef"><head>Scope and Contents</head><p>Southeast Asia Province file--designed to facilitate analysis of friendly and enemy military and pacification activity at the province level. Summarized data is organized by month for Province Corps, Viet Cong Military Regions, Division Tactical Areas, Special Tactical Zones, and Countrywide. Some fields use data from or indicators developed by HES.</p></scopecontent><c02 id="aspace_d5b001804acd401c19fab67b9efd7f75" level="file"><did><unittitle>Southeast Asia Province (also includes Hamlet Evaluations System Handbook),</unittitle><unitdate calendar="gregorian" era="ce" normal="1969/1969">1969</unitdate><container id="aspace_b0beb2f8cca86ba29d9b669d43eafcda" label="Mixed Materials [31924065231767]" type="box">1</container><container id="aspace_cbad89cc2974df682ccbf9fe052987f8" parent="aspace_b0beb2f8cca86ba29d9b669d43eafcda" type="folder">16</container></did></c02></c01><c01 id="aspace_4a3d61f1ddb04b830dd4a41df2f1f50e" level="series"><did><unittitle>Series IV. PAAS</unittitle></did><scopecontent id="aspace_e75fbddf53c7b2c3af270ce4a8e1ae6e"><head>Scope and Contents</head><p>Pacification Attitude Analysis System. Automated system to provide the Military Assistance Command Civil Operations and Rural Development Support, Pacification Study Group a means of processing and reporting the results of surveys to determine the attitudes of the Vietnamese people toward pacification, the War, and political, social, and economic development.</p><p> Data gathering instrument--semi-structured informal interview:</p><list numeration="arabic" type="ordered"><item>Respondent--Hamlet residents chosen by quota sampling techniques</item><item>Sample size--Selected sample of hamlets in each district, sample varying in size of province</item><item>Frequency of reporting--Data is reported monthly, each month's data representing sampling of a different group of districts</item></list></scopecontent><c02 id="aspace_e6f72e7d40c0d0c466b7334a29a43897" level="file"><did><unittitle>Functional Description for Pacification Attitude Analysis System (PAAS),</unittitle><unitdate calendar="gregorian" era="ce" normal="1970-01-25/1970-01-25">Jan. 25, 1970</unitdate><container id="aspace_4827d8a3cb43901a960b0f32e5db2a24" label="Mixed Materials [31924065231767]" type="box">1</container><container id="aspace_77f6460d7d6a6dd15d6ef418d4056b49" parent="aspace_4827d8a3cb43901a960b0f32e5db2a24" type="folder">17</container></did></c02><c02 id="aspace_3bcde3b5815249b23ecb8f8707fdde8d" level="file"><did><unittitle>Command Manual for Pacification Attitude Analysis System (PAAS),</unittitle><unitdate calendar="gregorian" era="ce" normal="1970-05-15/1970-05-15">May 15, 1970</unitdate><container id="aspace_7be02b6f7b993d3ad31dcb3f320406c6" label="Mixed Materials [31924065231767]" type="box">1</container><container id="aspace_3822d6ccc8ffd6a52a0aa9117a5539dd" parent="aspace_7be02b6f7b99