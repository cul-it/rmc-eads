      <dsc type="combined">
         <head>CONTAINER LIST</head>
         <c01 level="item">
            <did>
               <unitid>Item 1</unitid>
               <unittitle>Hector Falls Dry Goods Store Daybook, </unittitle><unitdate>(1822-1824)</unitdate>
            </did>
            <scopecontent>
               <p>54l pages containing name of customer, purchases, and whether paid by cash or
                  draft.</p>
            </scopecontent>
         </c01>
         <c01 level="item">
            <did>
               <unitid>Item 2</unitid>
               <unittitle>Unidentified ledger </unittitle><unitdate certainty="approximate">(Dec. 24, 1822-Aug. 13, 1824)</unitdate>
            </did>
            <scopecontent>
               <p>Contains an alphabetical index to names of individuals with accounts, and customer
                  accounts for newspaper subscriptions or individual copies.</p>
            </scopecontent>
         </c01>
         <c01 level="item">
            <did>
               <unitid>Item 3</unitid>
               <unittitle>Account Book </unittitle><unitdate>(June 16, l825-0ct. 13, 1826)</unitdate>
            </did>
            <scopecontent>
               <p>Microfilm copy. 54l pages. A 16" by 7" leather bound volume, marked "Journal," the
                  pages are headed with "Hector Falls." Entries as in item 1.</p>
            </scopecontent>
         </c01>
         <c01 level="item">
            <did>
               <unitid>Item 4</unitid>
               <unittitle>Ino H. Osborn &amp; Co., Account Book. </unittitle><unitdate>(Jan. 3, 1823-May 9,
                     1826)</unitdate>
            </did>
            <scopecontent>
               <p>Microfilm copy. pt. 1: List of customers who exchanged ashes for goods or cash,
                  pt. 2: 7 pages of receipts for grapes, n.d., and list of customers of hoop poles
                  (Jan. 1, 1823-Feb. 3, 1826)</p>
            </scopecontent>
         </c01>
      </dsc>
