			<unittitle encodinganalog="MARC 245" label="Title:">Cornell Graphic records, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1923-1926.</unitdate>
			<unitid label="Collection Number:">37-7-1987</unitid>
			<physdesc encodinganalog="MARC 300" label="Quantity:"><extent>2 cubic feet</extent></physdesc>
			<physdesc label="Forms of Material:">Photographs</physdesc>
			<repository label="Repository:">Division of Rare and Manuscript Collections, Cornell
				University Library</repository>
			<abstract label="Abstract:">Photographs associated with the publication,
				1923-1926.</abstract>
			<langmaterial label="Language:">Collection material in <language encodinganalog="041" langcode="eng">English</language></langmaterial>
		</did>
		<scopecontent encodinganalog="MARC 520">
			<head id="a3">COLLECTION DESCRIPTION</head>
			<p>Photographs associated with the publication, 1923-1926; some were used, but most were not published. Mostly photos of Cornell University events, athletics, student activities, faculty, performances, military, rush, stunt pictures, campus views and buldings. Also contains some non-Cornell photos of actors and actresses used in the publication. </p>
		</scopecontent>
