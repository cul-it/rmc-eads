         <head id="a1">DESCRIPTIVE SUMMARY</head>
         <unittitle encodinganalog="MARC 245" label="Title:">Cornell Oral History Program records, </unittitle>
         <unitdate encodinganalog="MARC 245" type="inclusive">1964-1974.</unitdate>
         <unitid label="Collection Number:">13-6-1747</unitid>
         <origination label="Creator:">

            <corpname encodinganalog="MARC 110">Cornell University.Program in Oral
               History.</corpname>

         </origination>
         <physdesc encodinganalog="MARC 300" label="Quantity:">
            <extent>5 cubic feet</extent>
         </physdesc>
         <physdesc label="Forms of Material:">Correspondence, financial records, travel records,
            seminars, talks, papers, and other material.</physdesc>
         <repository label="Repository:"> Division of Rare and Manuscript Collections, Cornell
            University Library </repository>
         <abstract label="Abstract:">Includes correspondence and printed material relating to the
            formation of the Oral History Association and the conduct of oral history colloquia;
            correspondence related to the Oral History Program at Cornell University, directed by
            Gould P. Colman; projects undertaken or proposed; financial records; payrolls; travel
            records; records relating to the Sarah Diamant film project; and seminars, talks, and
            papers on oral history by Colman.</abstract>
         <langmaterial label="Language:">Collection material in <language encodinganalog="041"
               langcode="eng">English</language>
         </langmaterial>
      </did>
      <scopecontent encodinganalog="MARC 520">
         <head id="a3">COLLECTION DESCRIPTION</head>
         <p>Includes correspondence and printed material relating to the formation of the Oral
            History Association and the conduct of oral history colloquia; correspondence related to
            the Oral History Program at Cornell University, directed by Gould P. Colman; projects
            undertaken or proposed; financial records; payrolls; travel records; records relating to
            the Sarah Diamant film project; and seminars, talks, and papers on oral history by
            Colman.</p>
      </scopecontent>
