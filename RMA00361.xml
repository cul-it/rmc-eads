			<head id="a1">DESCRIPTIVE SUMMARY</head>
			<unittitle encodinganalog="MARC 245" label="Title:">Cornell University reunion
				miscellany, </unittitle><unitdate encodinganalog="MARC 245" type="inclusive">1871-2010.</unitdate>
			<unitid label="Collection Number:">41-4-361</unitid>
			<physdesc encodinganalog="MARC 300" label="Quantity:"><extent>3.5 cubic feet</extent></physdesc>
			<physdesc label="Forms of Material:">Pamphlets, Newsletters, Newspaper articles,
				Photographs, Programs, Class directories, Broadsides.</physdesc>
			<repository label="Repository:">Division of Rare and Manuscript Collections, Cornell
				University Library</repository>
			<abstract label="Abstract:">Primarily programs and pamphlets relating to reunion
				activities of various Cornell classes.</abstract>
			<langmaterial label="Language:">Collection material in <language encodinganalog="041" langcode="eng">English</language>
			</langmaterial>
		</did>
		<scopecontent encodinganalog="MARC 520">
			<head id="a3">COLLECTION DESCRIPTION</head>
			<p>Primarily programs and pamphlets relating to reunion activities of various Cornell
				classes. Also included are broadsides, programs, class directories, photographs,
				newsletters, correspondence, clippings, and other materials related to many classes
				and reunions.</p>
		</scopecontent>
